{
  "expo": {
    "name": "MaestroScan",
    "slug": "my-app",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "maestroscan",
    "userInterfaceStyle": "dark",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/images/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#0A1628"
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.maestroscan.app",
      "buildNumber": "4",
      "infoPlist": {
        "NSCameraUsageDescription": "MaestroScan needs camera access to scan answer sheets.",
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "package": "com.maestroscan.app",
      "versionCode": 2,
      "permissions": [
        "CAMERA",
        "android.permission.CAMERA",
        "android.permission.RECORD_AUDIO"
      ],
      "adaptiveIcon": {
        "backgroundColor": "#0A1628",
        "foregroundImage": "./assets/images/android-icon-foreground.png",
        "backgroundImage": "./assets/images/android-icon-background.png",
        "monochromeImage": "./assets/images/android-icon-monochrome.png"
      }
    },
    "web": {
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      [
        "expo-router",
        {
          "origin": "https://maestroscan.app/"
        }
      ],
      "expo-font",
      "expo-web-browser",
      "expo-camera",
      [
        "react-native-vision-camera",
        {
          "cameraPermissionText": "MaestroScan needs camera access to scan answer sheets."
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    },
    "extra": {
      "router": {
        "origin": "https://maestroscan.app/"
      },
      "eas": {
        "projectId": "8c2587a0-cc5c-4976-b9ec-0e73dc6f6256"
      }
    },
    "owner": "martsonic901"
  }
}
